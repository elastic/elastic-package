inputs:
    - data_stream:
        namespace: ep
      meta:
        package:
            name: with_legacy_policy_api
      name: test-staging-with_legacy_policy_api
      streams:
        - data_stream:
            dataset: with_legacy_policy_api.indicator
          exclude_files:
            - .gz$
          paths:
            - /var/log/stag-*.log
          processors:
            - add_locale: null
            - add_tags:
                tags:
                    - revoked_false
                    - env_staging
      type: logfile
      use_output: default
output_permissions:
    default:
        _elastic_agent_checks:
            cluster:
                - monitor
        _elastic_agent_monitoring:
            indices: []
        uuid-for-permissions-on-related-indices:
            indices:
                - names:
                    - logs-with_legacy_policy_api.indicator-ep
                  privileges:
                    - auto_configure
                    - create_doc
secret_references: []
